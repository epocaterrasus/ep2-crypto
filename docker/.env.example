# docker/.env.example
# Copy to docker/.env and fill in real values before running docker compose.
# NEVER commit docker/.env — it is gitignored.
#
# In production, Doppler injects secrets at runtime.
# The DOPPLER_TOKEN below is the only value docker-compose needs from the host;
# everything else comes through Doppler into the running container.

# ---------------------------------------------------------------------------
# Doppler
# ---------------------------------------------------------------------------
# Service token for the ep2-crypto project, prd config.
# Create with: doppler configs tokens create --project ep2-crypto --config prd deploy-token
DOPPLER_TOKEN=dp.st.REPLACE_ME

# ---------------------------------------------------------------------------
# PostgreSQL / TimescaleDB
# ---------------------------------------------------------------------------
# Password for the TimescaleDB 'ep2' user.
# Must match EP2_DB_URL in the Doppler prd config.
POSTGRES_PASSWORD=REPLACE_ME

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
# Admin password — change on first login.
GRAFANA_PASSWORD=REPLACE_ME

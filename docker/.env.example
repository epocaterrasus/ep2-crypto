# Doppler service token for secrets injection
# Create one with:
#   doppler configs tokens create --project ep2-crypto --config prd deploy-token
DOPPLER_TOKEN=dp.st.xxxx

# TimescaleDB password (Doppler injects this at runtime for the app,
# but docker-compose needs it for the timescaledb service)
POSTGRES_PASSWORD=change_me_in_production

# Grafana admin password (change on first login)
GRAFANA_PASSWORD=changeme

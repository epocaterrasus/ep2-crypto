{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "barchart", "name": "Bar chart", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Trading PnL: cumulative equity curve, daily PnL bars, win rate, Sharpe, and max drawdown",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity"},
          "unit": "currencyUSD"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Cumulative PnL"},
            "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 9, "w": 18, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["last", "max", "min"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_cumulative_pnl_usd",
          "legendFormat": "Cumulative PnL"
        }
      ],
      "title": "Cumulative PnL (Equity Curve)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "green", "value": 1.5}
          ]},
          "min": -2,
          "max": 4
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 3, "x": 18, "y": 0},
      "id": 2,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_rolling_sharpe_24h",
          "legendFormat": "Sharpe"
        }
      ],
      "title": "Sharpe Ratio (24h)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.48},
            {"color": "green", "value": 0.52}
          ]},
          "min": 0.40,
          "max": 0.65
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 3, "x": 18, "y": 4},
      "id": 3,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_win_rate",
          "legendFormat": "Win Rate"
        }
      ],
      "title": "Win Rate",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "semi-dark-green", "mode": "fixed"},
          "custom": {"lineWidth": 1, "fillOpacity": 80},
          "unit": "currencyUSD",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 0}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "id": 4,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"},
        "xField": "Time",
        "stacking": {"mode": "none"},
        "fillOpacity": 80,
        "gradientMode": "none"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_daily_pnl_usd",
          "legendFormat": "Daily PnL"
        }
      ],
      "title": "Daily PnL",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "red", "mode": "fixed"},
          "custom": {"lineWidth": 2, "fillOpacity": 20},

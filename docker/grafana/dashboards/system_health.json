{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "System health: container CPU/memory, DB query latency, WebSocket reconnections, last prediction timestamp",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]},
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}, "type": "value"}
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "up{job=\"ep2-crypto\"}",
          "legendFormat": "API"
        }
      ],
      "title": "API Status",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 100},
            {"color": "red", "value": 500}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_prediction_latency_ms_p95",
          "legendFormat": "P95 Latency"
        }
      ],
      "title": "Prediction Latency P95",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 60},
            {"color": "red", "value": 300}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "time() - ep2_last_bar_timestamp",
          "legendFormat": "Staleness"
        }
      ],
      "title": "Data Staleness (last bar received)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 30},
            {"color": "red", "value": 120}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "time() - ep2_last_prediction_timestamp",
          "legendFormat": "Since Last Prediction"
        }
      ],
      "title": "Last Prediction Age",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]},
          "mappings": [
            {"options": {"0": {"text": "DISCONNECTED", "color": "red"}, "1": {"text": "CONNECTED", "color": "green"}}, "type": "value"}
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "id": 5,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_ws_connected{source=\"binance\"}",
          "legendFormat": "Binance WS"
        }
      ],
      "title": "Binance WebSocket",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 1}
          ]},
          "mappings": [
            {"options": {"0": {"text": "DISCONNECTED", "color": "red"}, "1": {"text": "CONNECTED", "color": "green"}}, "type": "value"}
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "id": 6,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_ws_connected{source=\"bybit\"}",
          "legendFormat": "Bybit WS"
        }
      ],
      "title": "Bybit WebSocket",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 7,
      "options": {"legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_prediction_latency_ms_p50",
          "legendFormat": "P50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_prediction_latency_ms_p95",
          "legendFormat": "P95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_prediction_latency_ms_p99",
          "legendFormat": "P99"
        }
      ],
      "title": "Prediction Latency Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"lineWidth": 1}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 8,
      "options": {"legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_db_query_latency_ms_p50",
          "legendFormat": "DB P50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_db_query_latency_ms_p95",
          "legendFormat": "DB P95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_db_query_latency_ms_p99",
          "legendFormat": "DB P99"
        }
      ],
      "title": "DB Query Latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.7},
            {"color": "red", "value": 0.9}
          ]},
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 12},
      "id": 9,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(process_cpu_seconds_total{job=\"ep2-crypto\"}[1m])",
          "legendFormat": "CPU Usage"
        }
      ],
      "title": "CPU Usage",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 2147483648},
            {"color": "red", "value": 3221225472}
          ]},
          "min": 0,
          "max": 4294967296
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 12},
      "id": 10,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "process_resident_memory_bytes{job=\"ep2-crypto\"}",
          "legendFormat": "RSS Memory"
        }
      ],
      "title": "Memory (RSS, max ~4GB)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "none", "custom": {"lineWidth": 1}},
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 12, "x": 12, "y": 12},
      "id": 11,
      "options": {"legend": {"calcs": ["last", "sum"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "increase(ep2_reconnect_count_total{source=\"binance\"}[1h])",
          "legendFormat": "Binance reconnects/hr"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "increase(ep2_reconnect_count_total{source=\"bybit\"}[1h])",
          "legendFormat": "Bybit reconnects/hr"
        }
      ],
      "title": "WebSocket Reconnection Rate (per hour)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "none", "custom": {"lineWidth": 1}},
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 17},
      "id": 12,
      "options": {"legend": {"calcs": ["last"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(ep2_messages_received_total{source=\"binance\"}[1m]) * 60",
          "legendFormat": "Binance msgs/min"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(ep2_messages_received_total{source=\"bybit\"}[1m]) * 60",
          "legendFormat": "Bybit msgs/min"
        }
      ],
      "title": "Ingest Message Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "none", "custom": {"lineWidth": 1}},
        "overrides": []
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 17},
      "id": 13,
      "options": {"legend": {"calcs": ["last", "sum"], "displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "increase(ep2_errors_total[1h])",
          "legendFormat": "Errors/hr"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "ep2_reconnect_count_total",
          "legendFormat": "Total Reconnects (all time)"
        }
      ],
      "title": "Errors & Total Reconnects",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["system", "health", "ep2-crypto"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "System Health",
  "uid": "ep2-system-health",
  "version": 1
}

# .env.example — ep2-crypto environment variable reference
#
# This file documents EVERY environment variable the codebase reads.
# Copy to .env for local development ONLY — .env is gitignored.
#
# Production: all secrets come from Doppler (project: ep2-crypto, config: prd).
# Run `doppler run -- uv run python scripts/live.py` to inject them.
#
# Pydantic Settings env_prefix mapping:
#   EP2_              → AppConfig          (src/ep2_crypto/config.py)
#   EP2_EXCHANGE_     → ExchangeConfig
#   EP2_DB_           → DatabaseConfig
#   EP2_PIPELINE_     → PipelineConfig
#   EP2_MONITOR_      → MonitoringConfig
#   EP2_API_          → ApiConfig
#   EP2_RISK_         → RiskConfig         (src/ep2_crypto/risk/config.py)

# ===========================================================================
# Application
# ===========================================================================
EP2_ENV=dev                    # dev | staging | prod
EP2_DEBUG=false
EP2_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
EP2_DATA_DIR=data

# ===========================================================================
# Exchange APIs  (DOPPLER — never commit real values)
# ===========================================================================
# Binance USDT-M perpetuals  (read by live_exchange.py and ExchangeConfig)
EP2_EXCHANGE_BINANCE_API_KEY=REPLACE_ME
EP2_EXCHANGE_BINANCE_API_SECRET=REPLACE_ME

# Bybit (OI, funding, liquidations)
EP2_EXCHANGE_BYBIT_API_KEY=REPLACE_ME
EP2_EXCHANGE_BYBIT_API_SECRET=REPLACE_ME

# Note: live_exchange.py also reads bare BINANCE_API_KEY / BINANCE_API_SECRET
# (without the EP2_EXCHANGE_ prefix) as a fallback.  Both should be set.
BINANCE_API_KEY=REPLACE_ME
BINANCE_API_SECRET=REPLACE_ME

# ===========================================================================
# Cross-market data  (DOPPLER)
# ===========================================================================
# Twelve Data API key ($29/mo plan) — provides 1-min NQ/DXY bars.
# If absent, the collector falls back to yfinance (15-min delayed).
TWELVE_DATA_API_KEY=REPLACE_ME

# ===========================================================================
# Database
# ===========================================================================
# Backend: "sqlite" (dev default) or "timescaledb" (prod)
EP2_DB_BACKEND=sqlite
EP2_DB_SQLITE_PATH=data/ep2_crypto.db

# TimescaleDB / PostgreSQL DSN — required when EP2_DB_BACKEND=timescaledb.
# Also read directly as EP2_DB_URL by scripts (connection.py, train.py, etc.).
EP2_DB_TIMESCALEDB_URL=postgresql://ep2:REPLACE_ME@localhost:5432/ep2_crypto
EP2_DB_URL=postgresql://ep2:REPLACE_ME@localhost:5432/ep2_crypto

# ===========================================================================
# Monitoring & Alerts
# ===========================================================================
# Telegram bot for trade notifications and kill-switch alerts.
# Create a bot at https://t.me/BotFather and get the chat ID with @userinfobot.
EP2_TELEGRAM_BOT_TOKEN=REPLACE_ME
EP2_TELEGRAM_CHAT_ID=REPLACE_ME

# Slack incoming webhook (optional secondary alert channel).
EP2_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_ME

# ===========================================================================
# Polymarket CLOB execution  (DOPPLER)
# ===========================================================================
# Ethereum private key (hex, no 0x prefix) for signing CLOB orders on Polygon.
POLYMARKET_PRIVATE_KEY=REPLACE_ME
# USDC funder wallet address on Polygon mainnet.
POLYMARKET_FUNDER_ADDRESS=REPLACE_ME

# ===========================================================================
# Risk engine  (override defaults from RiskConfig; all optional)
# ===========================================================================
# EP2_RISK_DAILY_LOSS_LIMIT=0.03
# EP2_RISK_WEEKLY_LOSS_LIMIT=0.05
# EP2_RISK_MAX_DRAWDOWN_HALT=0.15
# EP2_RISK_MAX_RISK_PER_TRADE=0.01    # NEVER exceed 0.01 — see Monte Carlo notes
# EP2_RISK_KELLY_FRACTION=0.25
# EP2_RISK_MAX_TRADES_PER_DAY=30
# EP2_RISK_TRADING_START_HOUR_UTC=8
# EP2_RISK_TRADING_END_HOUR_UTC=21

# ===========================================================================
# Pipeline / model  (override defaults from PipelineConfig; all optional)
# ===========================================================================
# EP2_PIPELINE_CONFIDENCE_THRESHOLD=0.60
# EP2_PIPELINE_TRAINING_WINDOW_DAYS=14

# ===========================================================================
# API server  (override defaults from ApiConfig; all optional)
# ===========================================================================
# EP2_API_HOST=0.0.0.0
# EP2_API_PORT=8000
# EP2_API_LOG_LEVEL=info
